# Project-wide SwiftFormat config. Run via `swiftformat .` or pre-commit hook.
# Style matches docs/research-swift-performance.md §10.

--swiftversion 5.9
--indent 4
--maxwidth 120
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--closingparen balanced
--commas inline
--trimwhitespace always
--stripunusedargs closure-only
--semicolons never
--self remove
--marktypes always
--markextensions always
--organizetypes class,struct,enum,actor
--header strip
